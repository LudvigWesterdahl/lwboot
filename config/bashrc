#
# ~/.bashrc
#

# If not running interactively, don't do anything
[[ $- != *i* ]] && return

# =============================
# ===   alias definitions   ===
# =============================
alias slock="loginctl lock-session"
alias slogout="qdbus6 org.kde.Shutdown /Shutdown logout"
alias ls="ls --color=tty"
alias grep='grep --color=tty'
alias top="top -e m -E m -o RES"
alias wgetmbak="wget --mirror --convert-links --adjust-extension --no-parent --random-wait -e robots=off --reject=jpg,jpeg,png,gif,webp,svg,bmp,tiff,ico,mp4,avi,mov,wmv,flv,webm,pdf,zip,rar,iso,exe"
alias java21doc="braved /usr/share/doc/java21-openjdk/index.html"
alias java17spec="braved \$HOME/Documents/lwdoc/backup/docs.oracle.com.java17/javase/specs/jls/se17/html/index.html"
alias jdebugn="java -agentlib:jdwp=transport=dt_socket,server=y,suspend=n,address=*:5005"
alias jdebugy="java -agentlib:jdwp=transport=dt_socket,server=y,suspend=y,address=*:5005"
alias nvim1="NVIM_JDTLS_PNAME_SUFFIX=1 nvim"

#alias braved="rundisown brave"
alias braved="setsid -f brave >>\"\$HOME/.local/share/braved-brave.log\" 2>&1"
alias postmand="setsid -f postman >>\"\$HOME/.local/share/postmand-postman.log\" 2>&1"
alias vlcd="setsid -f vlc >>\"\$HOME/.local/share/vlcd-vlc.log\" 2>&1"
alias slackd="setsid -f slack >>\"\$HOME/.local/share/slackd-slack.log\" 2>&1"
alias dbeaverd="setsid -f dbeaver >>\"\$HOME/.local/share/dbeaverd-dbeaver.log\" 2>&1"

# ============================
# ===   helper functions   ===
# ============================
fmtjava() {
    local arg_dir_file="${1:-.}"

    /usr/share/idea/bin/format.sh \
        -s ~/.config/nvim/formatters/intellij-codestyle.xml \
        -m '*.java' \
        -r \
        "${arg_dir_file}"
}

dolphind() {
    local arg_dir="${1:-.}"

    if [ ! -d "${arg_dir}" ]; then
        echo "invalid directory: ${arg_dir}" 1>&2
        return 1
    fi

    setsid -f dolphin >> "$HOME/.local/share/dolphind-dolphin.log" 2>&1 "${arg_dir}"
}

mvnh() {
    arg_plugin="${1:-}"
    arg_goal="${2:-}"

    if [ "${arg_goal}" != "" ]; then
        mvn help:describe -e -Dplugin="${arg_plugin}" -Dgoal="${arg_goal}" -Ddetail=true
        return 0
    fi

    if [ "${arg_plugin}" != "" ]; then
        mvn help:describe -e -Dplugin="${arg_plugin}"
        return 0
    fi

    echo "USAGE"
    echo "    mvnh PLUGIN [GOAL]"
    echo ""
    echo "EXAMPLES"
    echo "    mvnh liquibase"
    echo "    mvnh liquibase rollbackSQL"

    return 0
}

gitra() {
    arg_run="${1:-}"

    if [ "${arg_run}" = "run" ]; then
        git commit --amend --reset-author --no-edit
        return 0
    fi

    echo "USAGE"
    echo "    gitra ARGUMENT"
    echo ""
    echo "EXAMPLES"
    echo "    gitra run"

    return 0
}





# ============================
# ===   environment vars   ===
# ============================
# skips history if same command
export HISTCONTROL=ignoredups
# increase history size
export HISTSIZE=5000
# command prompt
PS1='[\u:\w]$ '
# export java_home
export JAVA_HOME=/usr/lib/jvm/default
# https://donottrack.sh/
export DO_NOT_TRACK=1

# ================
# ===   misc   ===
# ================
# modify the umask from the 0022 default
umask 0002
# kernel stop intercepting <C-q> (0x11, ASCII XON) and <C-s> (0x13, ASCII XOFF), see stty -a, stty ixon to turn back on.
stty -ixon

