#!/bin/bash

installer_name="ghostty"
installer_description="Installs ghostty and copies config file."
installer_link="https://archlinux.org/packages/extra/x86_64/ghostty/"

pacman_pkg="extra/ghostty"

inst_help() {
    htitle "${installer_name}"
    hdesc
    htext "${installer_description}"
    husage
    htext "-"
    hexamples
    htext "-"
    hseealso
    htext "${installer_link}"
    htext "See install_kdeshortcuts"
}

inst_is_installed() {
    return 1
}

inst_can_install() {
    return 0
}

inst_install() {
    if ! is_pacman_installed ${pacman_pkg}; then
        pacman_install ${pacman_pkg}
    fi

    cp_bak config/ghostty.config ${HOME}/.config/ghostty/config

    return 0
}

inst_can_install_manual() {
    return 1
}

inst_install_manual() {
    return 0
}

inst_uninstall() {
    pacman_uninstall ${pacman_pkg}
}
