# Copy highlights.scm


inst_is_installed() {
    return 1
}

inst_can_install() {
    if ! is_command "unzip"; then
        echo "missing unzip"
        return 1
    fi
    
    return 0
}

inst_install() {
    if ! is_pacman_installed ${pacman_pkg}; then
        pacman_install ${pacman_pkg}
    fi
    
    mkdir $HOME/.config/nvim 2>/dev/null
    mkdir $HOME/.config/nvim/colors 2>/dev/null
    mkdir $HOME/.config/nvim/lua 2>/dev/null
    
    cp -v config/nvim/init.lua $HOME/.config/nvim/init.lua
    cp -v config/nvim/stylua.toml $HOME/.config/nvim/.stylua.toml

    cp_query "java"
    cp_query "c"
}

inst_can_install_manual() {
    return 1
}

inst_install_manual() {
    return 0
}

inst_uninstall() {
    pacman_uninstall ${pacman_pkg}
}
