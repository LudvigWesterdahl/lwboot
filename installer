#!/bin/sh
set -e
set -u

# ===========================================================================
# =========================        constants        =========================
# ===========================================================================

PROG_PATH="$(realpath "${0}")"
readonly PROG_PATH
PROG_DIR="$(dirname "${PROG_PATH}")"
# shellcheck disable=SC2034 # SC2034 (warning): PROG_DIR appears unused. Verify use (or export if used externally).
readonly PROG_DIR
PROG_NAME="$(basename "${PROG_PATH}")"
# shellcheck disable=SC2034 # SC2034 (warning): PROG_NAME appears unused. Verify use (or export if used externally).
readonly PROG_NAME


# ===========================================================================
# =========================        arguments        =========================
# ===========================================================================

# Argument 1: install | manual | uninstall | docs
readonly installer_arg="${1:-}"

# Argument 2: false | true, defaults to true
# If installer_arg is install and this is false skips upgrading pacman.
readonly installer_opt_1="${2:-}"

# ===========================================================================
# =========================          main           =========================
# ===========================================================================
# shellcheck disable=SC1091 # SC1090 (warning): ShellCheck can't follow non-constant source. Use a directive to specify location.
. ./installer_lib

# Placeholders to be provided by the individual installers.
installer_name=""
installer_description=""
# shellcheck disable=SC2034 # SC2034 (warning): installer_link appears unused. Verify use (or export if used externally).
installer_link=""
describe_installer() {
    printf '\033[1;38;2;122;166;218m%s\033[0m - %s\n' "${installer_name}" "${installer_description}"
}

run_install_out_1=""
run_install() {
    arg_installer="${1:-}"

    # shellcheck disable=SC1090 # SC1090 (warning): ShellCheck can't follow non-constant source. Use a directive to specify location.
    . "./${arg_installer}"

    if [ "${installer_arg}" = "install" ]; then

        describe_installer

        if inst_is_installed; then
            return 0
        fi

        if inst_can_install; then
            if ! inst_install; then
                bold_red "failed inst_install for ${arg_installer}"
                return 1
            fi
        else
            bold_yellow "skipping inst_install for ${arg_installer}"
        fi

        return 0
    fi

    if [ "${installer_arg}" = "manual" ]; then
        if inst_can_install_manual; then

            describe_installer

            inst_install_manual
        fi

        return 0
    fi


    if [ "${installer_arg}" = "uninstall" ]; then

        describe_installer

        if inst_is_installed; then
            if ! inst_uninstall; then
                bold_red "failed inst_uninstall for ${arg_installer}"
                return 1
            fi
        else
            bold_yellow "skipping not installed ${arg_installer}"
        fi

        return 0
    fi

    if [ "${installer_arg}" = "docs" ]; then
        inst_help_res=$(inst_help) || {
            bold_red "failed to call inst_help: ${arg_installer}"
            return 1
        }
        run_install_out_1="$(printf '%s%s\n\n\nx' "${run_install_out_1}" "${inst_help_res}")"
        run_install_out_1="${run_install_out_1%x}"
    fi
}

pacman_upgrade() {
    sudo pacman --noconfirm -Syu
    sudo pacman --noconfirm -Fy
}

if [ "${installer_arg}" = "install" ] && [ "${installer_opt_1}" != "false" ]; then
    pacman_upgrade
fi

if [ "${installer_arg}" = "uninstall" ]; then
    pacman_upgrade
fi

run_install install_docs
run_install install_docs_keybinds_arch
run_install install_docs_keybinds_ghostty
run_install install_docs_keybinds_nvim
run_install install_nuphykeyboard
run_install install_less
run_install install_gzip
run_install install_xz
run_install install_tar
run_install install_zip
run_install install_unzip
run_install install_vim
run_install install_git
run_install install_basedevel
run_install install_gcc
run_install install_gdb
run_install install_brave
run_install install_archwallpaper
run_install install_xorgxev
run_install install_evtest
run_install install_mandb
run_install install_manpages
run_install install_fonts
run_install install_ghostty
run_install install_bashrc
run_install install_kdeshortcuts
run_install install_libinputtools
run_install install_kdesettings
run_install install_shellcheck
run_install install_jq
run_install install_tokei
run_install install_slack
run_install install_java
run_install install_maven
run_install install_qpdf
run_install install_wlclipboard
run_install install_fd
run_install install_jdtls
run_install install_nvim
run_install install_libiconv
run_install install_feh
run_install install_hexyl
run_install install_tealdeer
run_install install_clang
run_install install_pacmancontrib
run_install install_intellij
run_install install_postman
run_install install_vlc
run_install install_mullvad
run_install install_gitleaks
run_install install_docker
run_install install_mariadbclients
run_install install_dbeaver
run_install install_usbutils
run_install install_calibre

if [ "${installer_arg}" = "docs" ]; then
    echo "${run_install_out_1}" | less
fi

